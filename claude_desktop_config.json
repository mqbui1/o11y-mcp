{
  "mcpServers": {
    "splunk-observability": {
      "command": "/usr/local/bin/uv",
      "args": [
        "run",
        "--with",
        "mcp[cli]",
        "--script",
        "/Users/marcbui/Documents/o11y-mcp/server.py"
